# ─── Property ────────────────────────────────────────────────────────────────
# Public URL of your deployed site (no trailing slash). Required for Stripe redirects.
NEXT_PUBLIC_URL=https://your-property.com

# ─── Admin Authentication ─────────────────────────────────────────────────────
# Secret used to sign/verify admin session tokens. Generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Email address that receives the OTP login code (must match adminEmail in config.json)
ADMIN_EMAIL=owner@your-property.com

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) during development; live keys (sk_live_...) in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
# Leave blank to use the dev provider (writes email previews to .email-previews/)
RESEND_API_KEY=re_...

# Email address that Resend sends FROM (must be verified in your Resend account)
EMAIL_FROM=reservations@your-property.com

# Set to "resend" in production; leave blank or "dev" to preview emails as HTML files
EMAIL_PROVIDER=resend

# ─── File Storage (Vercel Blob) ───────────────────────────────────────────────
# Required in production for persistent file storage (images, content, bookings).
# Get this from your Vercel project → Storage → Blob → .env.local
# Leave blank in local development to use the local filesystem instead.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Leave blank to disable analytics entirely.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── OTP (optional) ───────────────────────────────────────────────────────────
# OTP code expiry in minutes (default: 10)
OTP_TTL_MINUTES=10
