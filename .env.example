# ─── Property ────────────────────────────────────────────────────────────────
# Public URL of your deployed site (no trailing slash). Required for Stripe redirects.
NEXT_PUBLIC_URL=https://your-property.com

# ─── Admin Authentication ─────────────────────────────────────────────────────
# Secret used to sign/verify admin session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Email address that receives the OTP login code.
# This is the ONLY account that can log into the admin panel.
# It is set once at installation and should never change.
# It does NOT have to match the adminEmail in the database content —
# that field is for booking notification routing and is configurable from the admin panel.
ADMIN_EMAIL=your-login@example.com

# ─── Supabase (database + file storage) ──────────────────────────────────────
# Create a free project at https://supabase.com
# Find these in: Project Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role key — server-side only, never expose to the browser.
# Gives full database access, bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) during development; live keys (sk_live_...) in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email ────────────────────────────────────────────────────────────────────
# Choose one provider: "smtp" or leave blank/"dev" to write previews to disk.
EMAIL_PROVIDER=smtp

# Sender address shown to guests (e.g. "Villa Amara <reservations@your-property.com>")
EMAIL_FROM=reservations@your-property.com

# ── SMTP (Hostinger / Gmail app-password / any SMTP server) ──────────────────
# Hostinger: SMTP_HOST=smtp.hostinger.com  SMTP_PORT=465  SMTP_SECURE=true
# Gmail:     SMTP_HOST=smtp.gmail.com      SMTP_PORT=465  SMTP_SECURE=true
#            (use a 16-char App Password from myaccount.google.com/apppasswords)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=reservations@your-property.com
SMTP_PASS=your-email-password

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Leave blank to disable analytics entirely.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── OTP (optional) ───────────────────────────────────────────────────────────
# OTP code expiry in minutes (default: 10)
OTP_TTL_MINUTES=10
