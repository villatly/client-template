# ============================================================
# VARIABLES DE ENTORNO — client-template (Villatly)
# ============================================================
# INSTRUCCIONES:
#   - Para Vercel: importa este archivo en
#     Settings → Environment Variables → Import .env
#   - Para desarrollo local: copia este archivo como .env.local
#     y rellena los valores reales
#
# Rellena TODOS los valores marcados con <...> antes de desplegar
# ============================================================


# ─── GENERAL ──────────────────────────────────────────────────────────────────

# URL pública del sitio (sin barra final) — usada en redirects de Stripe y emails
NEXT_PUBLIC_URL=https://<TU-DOMINIO.COM>

# Email del administrador — recibirá el código OTP para entrar al panel admin
# Es la ÚNICA cuenta que puede acceder al admin, no se puede cambiar desde el panel
ADMIN_EMAIL=<admin@TU-DOMINIO.COM>


# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Crea tu proyecto en https://supabase.com (gratis)
# Project Settings → API

# URL del proyecto (ej: https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://<XXXXXXXXXXXX>.supabase.co

# Clave service_role — solo servidor, NUNCA exponer al navegador
# Tiene acceso total a la base de datos y bypasea RLS
SUPABASE_SERVICE_ROLE_KEY=<eyJ...>


# ─── STRIPE ───────────────────────────────────────────────────────────────────
# Crea tu cuenta en https://stripe.com
# Developers → API Keys → Secret key
# Usa sk_test_... en pruebas y sk_live_... en producción

STRIPE_SECRET_KEY=<sk_test_...>

# Developers → Webhooks → Signing secret
# Endpoint: https://TU-DOMINIO.COM/api/webhooks/stripe
# Eventos: checkout.session.completed, checkout.session.expired,
#          checkout.session.async_payment_succeeded, checkout.session.async_payment_failed
STRIPE_WEBHOOK_SECRET=<whsec_...>


# ─── AUTENTICACIÓN ────────────────────────────────────────────────────────────
# Clave secreta para firmar las sesiones de admin (HMAC-SHA256, 64 hex chars)
# Genera una nueva con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: usa un valor distinto en cada instalación / proyecto
ADMIN_SESSION_SECRET=47754c86d18c005a23fa8662a02d8be18813f82b4f6b8ffa014354658f79b3ac


# ─── EMAIL / SMTP ─────────────────────────────────────────────────────────────
# Proveedor de email: smtp | resend | dev
# "dev" no envía emails, los escribe en .email-previews/ (solo desarrollo local)
EMAIL_PROVIDER=smtp

# Dirección remitente que verán los huéspedes en los emails
EMAIL_FROM=<reservas@TU-DOMINIO.COM>

# Configuración SMTP — Hostinger
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=<reservas@TU-DOMINIO.COM>
SMTP_PASS=<CONTRASEÑA-DE-TU-CUENTA-DE-CORREO>

# Alternativa: Resend (deja vacío si usas SMTP)
# RESEND_API_KEY=re_...


# ─── ANALYTICS (opcional) ────────────────────────────────────────────────────
# Google Analytics 4 — deja vacío para desactivar
NEXT_PUBLIC_GA_ID=

# ─── OTP (opcional) ───────────────────────────────────────────────────────────
# Minutos de validez del código OTP de login (por defecto: 10)
OTP_TTL_MINUTES=10

# ─── VERCEL CRON (opcional) ───────────────────────────────────────────────────
# Secret para autenticar el cron job diario de sync iCal (Airbnb, Booking.com)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CRON_SECRET=
