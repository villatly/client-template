# ─────────────────────────────────────────────────────────────────────────────
# Environment variable template
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — this file is committed and safe to share.
#
# All three variables are REQUIRED. The app will refuse to start (in production)
# or return a clear 503 error (in development) if any are missing.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Stripe secret key ────────────────────────────────────────────────────────
#
# Where to get it:
#   Test mode:   https://dashboard.stripe.com/test/apikeys
#   Live mode:   https://dashboard.stripe.com/apikeys
#
# Format:
#   Test:  sk_test_51...
#   Live:  sk_live_51...
#
# Rules:
#   • Never use a live key in local development
#   • Never commit this file with a real key in it
#   • Rotate this key immediately if it is ever exposed
#
STRIPE_SECRET_KEY=sk_test_...

# ─── Stripe webhook signing secret ───────────────────────────────────────────
#
# This is how the webhook handler verifies that events actually come from Stripe.
# There are TWO different secrets — one for local dev, one for production:
#
# Local dev (Stripe CLI):
#   1. Install the Stripe CLI: https://stripe.com/docs/stripe-cli
#   2. Run: stripe listen --forward-to localhost:3000/api/webhooks/stripe
#   3. Copy the "webhook signing secret" printed on startup (whsec_...)
#   4. Paste it here as STRIPE_WEBHOOK_SECRET
#
# Production (Stripe Dashboard):
#   1. Go to: https://dashboard.stripe.com/webhooks
#   2. Create an endpoint pointing to: https://yourdomain.com/api/webhooks/stripe
#   3. Add events: checkout.session.completed, checkout.session.expired
#   4. Copy the "Signing secret" from the endpoint detail page
#   5. Set it in your deployment environment (Vercel, Railway, etc.)
#
# Format: whsec_...
#
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App base URL ─────────────────────────────────────────────────────────────
#
# Used to build the Stripe success_url and cancel_url:
#   success_url: ${NEXT_PUBLIC_URL}/booking/success?id=...
#   cancel_url:  ${NEXT_PUBLIC_URL}/booking/cancel?id=...
#
# Development:  http://localhost:3000
# Production:   https://yourdomain.com  ← must be https:// in live mode
#
NEXT_PUBLIC_URL=http://localhost:3000

# ─── Admin authentication ─────────────────────────────────────────────────────
#
# Secret used to sign the admin session cookie (HMAC-SHA256).
# Without this, the admin panel cannot be accessed.
#
# Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Rules:
#   • Must be at least 32 characters
#   • Never commit this value
#   • Rotate if exposed — all active sessions will be invalidated
#   • Use a different value in each environment (dev / staging / prod)
#
ADMIN_SESSION_SECRET=

# ─── Email ────────────────────────────────────────────────────────────────────
#
# EMAIL_PROVIDER selects the sending backend:
#   "dev"    — default, zero config. Writes HTML files to .email-previews/
#              Open them in a browser to preview exactly what guests will see.
#   "resend" — sends real emails via Resend. Requires RESEND_API_KEY.
#
# Development: leave this as "dev" — no external service needed.
# Production:  set to "resend" (or another supported provider).
#
EMAIL_PROVIDER=dev

# ─── Sender address ───────────────────────────────────────────────────────────
#
# The "From:" address shown to email recipients.
# Format: Display Name <address@yourdomain.com>
#
# Rules:
#   • In production, use a domain you own and have verified with your provider.
#   • When using Resend, the domain must be verified in your Resend account.
#   • If not set, falls back to: {property name} <noreply@example.com>
#
# EMAIL_FROM=Villa Amara Bali <noreply@yourdomain.com>

# ─── Resend API key ───────────────────────────────────────────────────────────
#
# Required when EMAIL_PROVIDER=resend.
#
# Where to get it:
#   https://resend.com/api-keys
#
# Format: re_...
#
# Rules:
#   • Never commit this value
#   • Rotate immediately if exposed
#
# RESEND_API_KEY=re_...

# ─── iCal cron secret ─────────────────────────────────────────────────────────
#
# Protects the GET /api/admin/ical/sync endpoint that Vercel Cron calls.
# Without this, the cron endpoint is open to anyone — set it in production.
#
# Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Vercel Cron automatically sends: Authorization: Bearer <CRON_SECRET>
# Set this same value in your Vercel project environment variables.
#
# If left empty, the endpoint is unauthenticated (fine for local dev, not prod).
#
# CRON_SECRET=
